---
const SITE_URL = 'https://vasprisin.com';
const pageTitle = 'Priyanshu Singh — vasprisin';
const pageDescription = 'Priyanshu Singh — founder, operator. Dolta, Capital Hunt, and seven other ventures. LDN / DXB / BOM.';
const ogImage = new URL('/assets/priyanshu-portrait.png', SITE_URL).toString();

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Priyanshu Singh',
  alternateName: 'vasprisin',
  url: SITE_URL,
  image: ogImage,
  jobTitle: 'Founder & Operator',
  description: pageDescription,
  worksFor: [
    { '@type': 'Organization', name: 'Dolta', url: 'https://dolta.io' },
    { '@type': 'Organization', name: 'Capital Hunt', url: 'https://capitalhunt.io' },
  ],
  sameAs: [
    'https://linkedin.com/in/vasprisin',
    'https://x.com/vasprisin',
    'https://instagram.com/vasprisin',
    'https://youtube.com/@vasprisin28',
    'https://github.com/vasprisin',
  ],
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'vasprisin',
  url: SITE_URL,
  author: { '@type': 'Person', name: 'Priyanshu Singh' },
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={SITE_URL + '/'} />

  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content="Priyanshu Singh — vasprisin" />
  <meta property="og:url" content={SITE_URL + '/'} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="vasprisin" />
  <meta property="og:locale" content="en_GB" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:creator" content="@vasprisin" />
  <meta name="twitter:site" content="@vasprisin" />

  <meta name="author" content="Priyanshu Singh" />
  <meta name="theme-color" content="#0f0f0f" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="256x256" href="/favicon-256.png" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="alternate" type="application/rss+xml" title="vasprisin — Writing" href="/rss.xml" />
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
    rel="stylesheet" />

  <link rel="stylesheet" href="/site.css" />

  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
</head>
<body>

<div class="vp-page">

  <!-- ============================================================
       HEADER
       ============================================================ -->
  <header class="vp-header" id="vp-header">
    <div class="vp-rule-strong-top"></div>
    <div class="vp-header-inner">
      <button class="vp-menu-btn" id="vp-menu-btn" aria-label="Open menu" aria-controls="vp-drawer" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <a class="vp-wordmark" href="#top"><em>vasprisin</em></a>
      <nav class="vp-nav">
        <a href="#about">About</a>
        <a href="#companies">Companies</a>
        <a href="#letters">Credentials</a>
        <a href="/blog">Blog</a>
        <a href="#contact">Contact</a>
      </nav>
      <div class="vp-header-meta">
        <a class="vp-header-social" href="https://linkedin.com/in/vasprisin" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5V9h3v10zM6.5 7.7A1.7 1.7 0 1 1 6.5 4.3a1.7 1.7 0 0 1 0 3.4zM19 19h-3v-5.3c0-1.3 0-2.9-1.8-2.9s-2 1.4-2 2.8V19h-3V9h2.9v1.4h.04A3.16 3.16 0 0 1 14.9 8.8c3 0 3.6 2 3.6 4.5V19z"></path></svg>
        </a>
        <a class="vp-header-social" href="https://instagram.com/vasprisin" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle></svg>
        </a>
        <a class="vp-header-social" href="https://x.com/vasprisin" target="_blank" rel="noopener" aria-label="X">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"></path></svg>
        </a>
        <a class="vp-header-social" href="https://youtube.com/@vasprisin28" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.6 3.5 12 3.5 12 3.5s-7.6 0-9.4.6A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.8.6 9.4.6 9.4.6s7.6 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-3.8.5-5.8a31.4 31.4 0 0 0-.5-5.8zM9.7 15.6v-7.2L15.8 12l-6.1 3.6z"></path></svg>
        </a>
      </div>
    </div>
    <div class="vp-rule"></div>
  </header>

  <main class="vp-main">

    <!-- ============================================================
         HERO  (light)
         ============================================================ -->
    <section class="vp-band vp-band--light">
      <div class="vp-band-inner">
        <section id="top" class="vp-hero">
          <div class="vp-hero-grid">
            <div class="vp-hero-left">
              <h1 class="vp-hero-name">Priyanshu&nbsp;<em>Singh</em></h1>
              <div class="vp-hero-tagline">
                <span>22&nbsp;Year&nbsp;Old</span>
                <span class="sep"></span>
                <span>Entrepreneur</span>
                <span class="sep"></span>
                <span>Investor</span>
                <span class="sep"></span>
                <span>Marketeer</span>
              </div>
              <p class="vp-hero-lede">
                I run ventures at the intersection of <em>capital</em> and <em>pipeline</em>,<br />
                building scalable systems that produce the top 1% results.
              </p>
              <a class="vp-hero-pill" href="#socials" aria-label="@vasprisin on all social media">
                <span class="vp-hero-pill-dot" aria-hidden="true">
                  <span class="vp-hero-pill-halo"></span>
                </span>
                <span class="vp-hero-pill-text">@vasprisin on all social media</span>
              </a>
            </div>
            <aside class="vp-hero-right">
              <img
                src="/assets/priyanshu-portrait.png"
                alt="Portrait of Priyanshu Singh"
                width="720"
                height="900"
                fetchpriority="high"
                decoding="async"
                class="vp-portrait-cutout" />
            </aside>
          </div>
        </section>
      </div>
    </section>

    <!-- ============================================================
         NUMBERS  (dark)
         ============================================================ -->
    <section class="vp-band vp-band--dark" aria-label="Numbers at a glance">
      <div class="vp-band-inner">
        <section class="vp-section vp-section-numbers">
          <div class="vp-numbers-head">
            <h2 class="vp-numbers-title">Some <em>Highlights.</em></h2>
          </div>
          <div class="vp-stats-grid">
            <div class="vp-stat">
              <div class="vp-stat-num">$22M<span class="vp-stat-unit">+</span></div>
              <div class="vp-stat-label">Revenue for clients</div>
            </div>
            <div class="vp-stat">
              <div class="vp-stat-num">148K<span class="vp-stat-unit">+</span></div>
              <div class="vp-stat-label">Leads generated</div>
            </div>
            <div class="vp-stat">
              <div class="vp-stat-num">200<span class="vp-stat-unit">+</span></div>
              <div class="vp-stat-label">B2B engagements</div>
            </div>
            <div class="vp-stat">
              <div class="vp-stat-num">3M<span class="vp-stat-unit">/mo</span></div>
              <div class="vp-stat-label">Email infra</div>
            </div>
            <div class="vp-stat">
              <div class="vp-stat-num">3,000<span class="vp-stat-unit"> acc.</span></div>
              <div class="vp-stat-label">LinkedIn rented</div>
            </div>
            <div class="vp-stat">
              <div class="vp-stat-num">$8M<span class="vp-stat-unit">+</span></div>
              <div class="vp-stat-label">Institutional flow</div>
            </div>
            <div class="vp-stat">
              <div class="vp-stat-num">10</div>
              <div class="vp-stat-label">Active ventures</div>
            </div>
            <div class="vp-stat">
              <div class="vp-stat-num">22</div>
              <div class="vp-stat-label">Years old</div>
            </div>
          </div>
        </section>
      </div>
    </section>

    <!-- ============================================================
         ABOUT  (light)
         ============================================================ -->
    <section class="vp-band vp-band--light vp-band--ends-with-portrait">
      <div class="vp-band-inner">
        <section id="about" class="vp-section vp-section--about">
          <div class="vp-section-head vp-section-head--center">
            <div class="vp-eyebrow">
              <span class="vp-eyebrow-num">01</span>
              <span class="vp-eyebrow-sep">—</span>
              <span>About</span>
            </div>
            <h2 class="vp-section-title">About <em>Priyanshu Singh.</em></h2>
          </div>

          <div class="vp-about-intro">
            <p>
              Started selling things in India as a kid (12) &mdash; lemonade, massages, even social
              media followers. That early obsession with sales and business eventually turned
              into building companies focused on one thing: <em>helping businesses grow faster</em>.
            </p>
          </div>

          <div class="vp-about-wrap">
            <div class="vp-about-col vp-about-col--left">
              <p>
                Over the past few years I&rsquo;ve worked with founders, funds, and growth teams
                across multiple industries, helping them generate pipeline, close clients,
                and access investors.
              </p>
              <p>
                Along the way I&rsquo;ve had the chance to meet hundreds of industry leaders,
                speak on podcasts, attend dozens of events, and get invited to the
                <em>House of Lords</em>.
              </p>
              <p class="vp-about-h"><strong>I help companies:</strong></p>
              <ul class="vp-letter-list">
                <li>Raise capital through <em>CapitalHunt</em></li>
                <li>Acquire clients and scale outbound through <em>Dolta</em></li>
                <li>Build and experiment with GTM and data SaaS tools</li>
              </ul>
            </div>

            <div class="vp-about-col vp-about-col--image">
              <img class="vp-about-portrait" src="/assets/priyanshu-about.png" alt="Priyanshu Singh — second portrait" loading="lazy" decoding="async" />
            </div>

            <div class="vp-about-col vp-about-col--right">
              <p>
                Today I work at the intersection of <em>capital, growth, and automation</em>.
              </p>
              <p class="vp-about-h"><strong>Some results my team has delivered:</strong></p>
              <ul class="vp-letter-list vp-letter-list--arrow">
                <li>300+ active clients</li>
                <li>150k+ leads generated</li>
                <li>100k+ LinkedIn event registrations</li>
                <li>$22M+ pipeline generated for clients</li>
                <li>$8M+ capital raised for startups</li>
                <li>Built a team from 0 &rarr; 28 people in under 2 years (now leaner with AI)</li>
              </ul>
              <p>
                Outside work I train, build things, and occasionally experiment with side projects.
              </p>
            </div>

            <!-- Full-bleed graphic lines that sit behind the portrait -->
            <div class="vp-about-spotlight" aria-hidden="true"></div>
            <div class="vp-about-bleed vp-about-bleed--bar1" aria-hidden="true"></div>
            <div class="vp-about-bleed vp-about-bleed--bar2" aria-hidden="true"></div>
            <div class="vp-about-bleed vp-about-bleed--rule" aria-hidden="true"></div>
          </div>
        </section>
      </div>
    </section>

    <!-- ============================================================
         COMPANIES  (light)
         ============================================================ -->
    <section class="vp-band vp-band--light">
      <div class="vp-band-inner">
        <section id="companies" class="vp-section">
          <div class="vp-section-head vp-section-head--noline">
            <div class="vp-eyebrow">
              <span class="vp-eyebrow-num">02</span>
              <span class="vp-eyebrow-sep">—</span>
              <span>Companies</span>
            </div>
            <h2 class="vp-section-title">My <em>Companies</em></h2>
          </div>

          <div class="vp-cos-grid">

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Dolta</div>
                <div class="vp-co-mark-sub">Lead generation</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Dolta</div>
              </div>
              <p class="vp-co-one">High-ticket B2B leadgen and LinkedIn agency. Outbound infrastructure for crypto institutions, family offices, and funded B2B.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">dolta.io</span>
                <a class="vp-co-visit" href="https://dolta.io" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Capital Hunt</div>
                <div class="vp-co-mark-sub">Investor intelligence</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Capital Hunt</div>
              </div>
              <p class="vp-co-one">The investor-intelligence layer for the next decade. Three sides — investors, founders, advisors. Central priority for the next twelve months.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">capitalhunt.io</span>
                <a class="vp-co-visit" href="https://capitalhunt.io" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Goaccounts</div>
                <div class="vp-co-mark-sub">Account procurement</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Goaccounts</div>
              </div>
              <p class="vp-co-one">LinkedIn account procurement and rental. 3,000+ accounts under management. The infrastructure layer beneath Arksend and Dolta outbound.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">goaccounts.ai</span>
                <a class="vp-co-visit" href="https://goaccounts.ai" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Arksend</div>
                <div class="vp-co-mark-sub">Outbound automation</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Arksend</div>
              </div>
              <p class="vp-co-one">LinkedIn outbound automation, positioned as the safest. Built for operators running cold outbound at volume without burning sender reputation.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">arksend.com</span>
                <a class="vp-co-visit" href="https://arksend.com" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Data Pimp</div>
                <div class="vp-co-mark-sub">315M+ records</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Data Pimp</div>
              </div>
              <p class="vp-co-one">B2B leads dataset built on BigQuery. ZoomInfo plus LinkedIn master table. The single source feeding every outbound campaign across the group.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">datapimp.io</span>
                <a class="vp-co-visit" href="https://datapimp.io" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Goenrich</div>
                <div class="vp-co-mark-sub">Enrichment API</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Goenrich</div>
              </div>
              <p class="vp-co-one">B2B data enrichment API on top of Data Pimp. Sold to agencies and revenue-ops teams who don&rsquo;t want to manage a warehouse.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">goenrich.cfd</span>
                <a class="vp-co-visit" href="https://goenrich.cfd" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Gosites</div>
                <div class="vp-co-mark-sub">AI web design</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Gosites</div>
              </div>
              <p class="vp-co-one">AI-powered web design. Sites at agency quality, agency-fast. The studio that ships our marketing pages overnight.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">gosites.uk</span>
                <a class="vp-co-visit" href="https://gosites.uk" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Fine City Club</div>
                <div class="vp-co-mark-sub">Invite only</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Fine City Club</div>
              </div>
              <p class="vp-co-one">Invite-only WhatsApp founder community. Operators and executives across London, Dubai, and Mumbai. Curated, not scaled.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">tfcc.space</span>
                <a class="vp-co-visit" href="https://tfcc.space" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

            <article class="vp-co">
              <div class="vp-co-plate">
                <div class="vp-co-mark">Anka's</div>
                <div class="vp-co-mark-sub">Cake café · Pune</div>
              </div>
              <div class="vp-co-meta">
                <div class="vp-co-name">Anka's</div>
              </div>
              <p class="vp-co-one">Luxury cake café in Pune. Family-owned, single store, multi-generational. The one I didn't build — and the one I'm proudest of being part of.</p>
              <div class="vp-co-actions">
                <span class="vp-co-domain">ankas.in</span>
                <a class="vp-co-visit" href="https://ankas.in" target="_blank" rel="noopener">Visit <span class="vp-co-visit-arrow">↗</span></a>
              </div>
            </article>

          </div>
        </section>
      </div>
    </section>

    <!-- ============================================================
         GALLERY  (dark) — 3 × 3 plates + view-gallery CTA
         ============================================================ -->
    <section class="vp-band vp-band--dark">
      <div class="vp-band-inner">
        <section id="gallery" class="vp-section">
          <div class="vp-section-head">
            <div class="vp-eyebrow">
              <span class="vp-eyebrow-num">03</span>
              <span class="vp-eyebrow-sep">—</span>
              <span>Gallery</span>
            </div>
            <h2 class="vp-section-title">Rooms, stages, <em>and cities.</em></h2>
          </div>

          <div class="vp-gallery-grid">
            <a class="vp-gallery-tile has-img" href="#gallery">
              <img src="/assets/gallery/kishore-lulla.jpeg" alt="With Kishore Lulla, Bollywood&rsquo;s biggest producer" loading="lazy" />
              <div class="vp-gallery-tile-caption"><em>Kishore Lulla</em>Bollywood&rsquo;s biggest producer</div>
            </a>
            <a class="vp-gallery-tile has-img" href="#gallery">
              <img src="/assets/gallery/house-of-lords.jpeg" alt="Afternoon Tea at the House of Lords with Sophie Newbound" loading="lazy" />
              <div class="vp-gallery-tile-caption"><em>House of Lords</em>Afternoon tea with Sophie Newbound</div>
            </a>
            <a class="vp-gallery-tile has-img" href="#gallery">
              <img src="/assets/gallery/gfois-dubai.jpeg" alt="VIP Delegate at the Global Family Office Investment Summit Dubai" loading="lazy" />
              <div class="vp-gallery-tile-caption"><em>GFOIS Dubai</em>VIP delegate, Global Family Office Summit</div>
            </a>
            <a class="vp-gallery-tile has-img" href="#gallery">
              <img src="/assets/gallery/lord-rami-ranger.jpeg" alt="Lord Rami Ranger gifts me his autobiography" loading="lazy" />
              <div class="vp-gallery-tile-caption"><em>Lord Rami Ranger</em>Gifts me his autobiography</div>
            </a>
            <a class="vp-gallery-tile has-img" href="#gallery">
              <img src="/assets/gallery/gala-dinner-dubai.jpeg" alt="At Gala Dinner in Dubai" loading="lazy" />
              <div class="vp-gallery-tile-caption"><em>Gala Dinner</em>Dubai</div>
            </a>
            <a class="vp-gallery-tile has-img" href="#gallery">
              <img src="/assets/gallery/ciros-pomodoro.jpeg" alt="With Ciro Orsini at the legendary Ciro&rsquo;s Pomodoro knightsbridge" loading="lazy" />
              <div class="vp-gallery-tile-caption"><em>Ciro Orsini</em>At Ciro&rsquo;s Pomodoro, Knightsbridge</div>
            </a>
            <a class="vp-gallery-tile has-img" href="#gallery">
              <img src="/assets/gallery/zebu-live.jpeg" alt="Attending Lord Kulveer Singh Ranger&rsquo;s talk at Zebu Live 2025" loading="lazy" />
              <div class="vp-gallery-tile-caption"><em>Lord Kulveer Singh Ranger</em>Attending his talk at Zebu Live 2025</div>
            </a>
